{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Fujin Design Tokens",
    "version": "0.1.0",
    "platform": "web+native",
    "description": "Shared token contract for Mantine (web) and React Native (native) UI projects"
  },

  "color": {
    "source": "mantine-open-color",
    "note": "All color values are derived from Mantine Open Color at runtime via the FujinThemeProvider preset. See themes/createFujinTheme.ts for the shade-to-semantic-role mapping.",
    "accentOptions": ["violet","indigo","blue","cyan","teal","green","orange"],
    "status": {
      "danger":  "red[6]",
      "warning": "yellow[6]",
      "success": "green[6]",
      "info":    "blue[6]"
    }
  },

  "spacing": {
    "base": 4,
    "scale": {
      "xxs": 2,
      "xs":  10,
      "sm":  12,
      "md":  16,
      "lg":  20,
      "xl":  24,
      "xxl": 32
    }
  },

  "typography": {
    "fontFamily": {
      "base": "\"Verdana\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
      "mono": "\"JetBrains Mono\", \"Fira Code\", \"Cascadia Code\", Menlo, Consolas, monospace"
    },
    "fontSize": {
      "xs":  10,
      "sm":  12,
      "md":  14,
      "lg":  16,
      "xl":  20,
      "xxl": 24,
      "h1":  32,
      "h2":  24,
      "h3":  20,
      "h4":  16,
      "h5":  14,
      "h6":  12
    },
    "fontWeight": {
      "regular":  400,
      "medium":   500,
      "semibold": 600,
      "bold":     700
    },
    "lineHeight": {
      "tight":   1.2,
      "base":    1.5,
      "relaxed": 1.75
    },
    "letterSpacing": {
      "tight":   "-0.02em",
      "base":    "0em",
      "wide":    "0.05em",
      "widest":  "0.1em"
    }
  },

  "radius": {
    "xs":      0,
    "sm":      0,
    "md":      0,
    "lg":      0,
    "xl":      0,
    "default": 0
  },

  "opacity": {
    "disabled": 0.5,
    "loading":  0.7
  },

  "shadow": {
    "xs": "none",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.4)",
    "md": "0 2px 4px rgba(0, 0, 0, 0.5)",
    "lg": "0 4px 8px rgba(0, 0, 0, 0.6)",
    "xl": "0 8px 16px rgba(0, 0, 0, 0.7)"
  },

  "breakpoints": {
    "xs": 576,
    "sm": 768,
    "md": 992,
    "lg": 1200,
    "xl": 1408
  },

  "transition": {
    "duration": {
      "fast": "100ms",
      "base": "150ms",
      "slow": "250ms"
    },
    "easing": {
      "default": "ease",
      "in":      "ease-in",
      "out":     "ease-out",
      "inOut":   "ease-in-out"
    }
  }
}
